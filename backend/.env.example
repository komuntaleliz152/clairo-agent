GROQ_API_KEY=your_groq_api_key_here

# Optional: better web search (free tier at https://tavily.com)
# TAVILY_API_KEY=your_tavily_api_key_here

# Use 8001 if 8000 is stuck/busy on Windows
PORT=8001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Clerk JWT issuer (Dashboard → API Keys → Advanced → JWT Issuer)
# Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# Local dev only — skip JWT checks (never use in production)
# DISABLE_AUTH=true
